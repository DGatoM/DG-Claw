{
  "description": "DG Claw — memoria local: recall por palavra-chave antes de responder, registro do fio do Telegram, e re-injecao de contexto no inicio/pos-compactacao. Tudo local, sem API externa.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-recall.sh\"",
            "timeout": 8
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.*telegram.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/log-reply.sh\"",
            "timeout": 6
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-context.sh\"",
            "timeout": 8
          }
        ]
      }
    ]
  }
}
